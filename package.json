  },
  "files": [
    "src/lib"
  ],
  "scripts": {
    "prebuild": "tsx scripts/build-css.ts",
    "build": "tsx scripts/build-css.ts",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@omnidea/crystal": "^0.1.0",
    "solid-js": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@omnidea/crystal": {
      "optional": true
    }
  },
  "dependencies": {
    "remixicon": "^4.6.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.11",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
