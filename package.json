{
  "name": "@omnidea/ui",
  "version": "2.0.0",
  "description": "Omnidea design system. Solid.js components + UnoCSS theme with Glass, Neu, and Crystal modes.",
  "type": "module",
  "main": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": "./src/lib/index.ts",
    "./theme.css": "./src/lib/theme.css",
    "./tokens": "./src/lib/tokens/index.ts",
